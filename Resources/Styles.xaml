<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:hc="https://handyorg.github.io/handycontrol">

    <!-- ===== 色彩体系 ===== -->
    <Color x:Key="BrandColor">#D97757</Color>
    <Color x:Key="BrandLightColor">#F97316</Color>
    <Color x:Key="BrandDarkColor">#EA580C</Color>

    <SolidColorBrush x:Key="BrandBrush" Color="#D97757"/>
    <SolidColorBrush x:Key="BrandLightBrush" Color="#F97316"/>
    <SolidColorBrush x:Key="BrandDarkBrush" Color="#EA580C"/>
    <SolidColorBrush x:Key="BrandBgBrush" Color="#FFF7ED"/>

    <SolidColorBrush x:Key="PageBgBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="#F1F5F9"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="BorderMutedBrush" Color="#F3F4F6"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
    <SolidColorBrush x:Key="SuccessBgBrush" Color="#F0FDF4"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="ErrorBgBrush" Color="#FEF2F2"/>

    <!-- ===== 圆角体系 ===== -->
    <CornerRadius x:Key="CornerRadiusCard">12</CornerRadius>
    <CornerRadius x:Key="CornerRadiusInput">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusButton">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusSmall">6</CornerRadius>
    <CornerRadius x:Key="CornerRadiusTag">4</CornerRadius>

    <!-- ===== 主按钮：品牌橙 ===== -->
    <Style x:Key="ButtonPrimary" TargetType="Button">
        <Setter Property="Height" Value="36"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#D97757"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource CornerRadiusButton}"
                            Padding="16,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#C4623E"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#B5573A"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#9CA3AF"/>
                            <Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 成功按钮：绿色 ===== -->
    <Style x:Key="ButtonSuccess" TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
        <Setter Property="Background" Value="#22C55E"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource CornerRadiusButton}"
                            Padding="16,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#16A34A"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#15803D"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#9CA3AF"/>
                            <Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 幽灵按钮：透明 + 品牌橙边框 ===== -->
    <Style x:Key="ButtonGhost" TargetType="Button">
        <Setter Property="Height" Value="38"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="#6B7280"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="#E5E7EB" BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusButton}"
                            Padding="16,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#D97757"/>
                            <Setter TargetName="Bd" Property="Background" Value="#FFFBF9"/>
                            <Setter Property="Foreground" Value="#D97757"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFF7ED"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 小按钮 ===== -->
    <Style x:Key="ButtonSmall" TargetType="Button">
        <Setter Property="Height" Value="28"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource CornerRadiusSmall}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 图标按钮（删除等） ===== -->
    <Style x:Key="ButtonIcon" TargetType="Button">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#9CA3AF"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource CornerRadiusSmall}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FEF2F2"/>
                            <Setter Property="Foreground" Value="#EF4444"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 添加服务商虚线按钮 ===== -->
    <Style x:Key="AddProviderButton" TargetType="Button">
        <Setter Property="Height" Value="52"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#6B7280"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" BorderBrush="#D0D5DD" BorderThickness="1,1,1,1"
                            CornerRadius="{StaticResource CornerRadiusCard}" Background="Transparent">
                        <Border.Clip>
                            <RectangleGeometry RadiusX="12" RadiusY="12">
                                <RectangleGeometry.Rect>
                                    <Rect X="0" Y="0" Width="800" Height="60"/>
                                </RectangleGeometry.Rect>
                            </RectangleGeometry>
                        </Border.Clip>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="22" Margin="0,-4,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#D97757"/>
                            <Setter TargetName="Bd" Property="Background" Value="#FFF7ED"/>
                            <Setter Property="Foreground" Value="#D97757"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 顶部 Tab 按钮 ===== -->
    <Style x:Key="TabButtonStyle" TargetType="RadioButton">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="#9CA3AF"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}"
                            Margin="2,0">
                        <StackPanel>
                            <ContentPresenter x:Name="Content" HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                            <Border x:Name="BottomIndicator" Height="3" CornerRadius="2"
                                    Background="#D97757" Margin="6,8,6,0" Opacity="0"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#6B7280"/>
                            <Setter TargetName="Bd" Property="Background" Value="#F9FAFB"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="#D97757"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter TargetName="BottomIndicator" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 分组卡片 ===== -->
    <Style x:Key="GroupCard" TargetType="hc:Card">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- ===== Provider 卡片（顶部色条） ===== -->
    <Style x:Key="ProviderCard" TargetType="Border">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 底部操作栏 ===== -->
    <Style x:Key="BottomBar" TargetType="Border">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Padding" Value="32,20"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <!-- ===== 分隔线 ===== -->
    <Style x:Key="Divider" TargetType="Separator">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="#F3F4F6"/>
        <Setter Property="Margin" Value="0,16"/>
    </Style>

    <!-- ===== 页面标题 ===== -->
    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#1F2937"/>
    </Style>

    <!-- ===== 小节标题 ===== -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#1F2937"/>
    </Style>

    <!-- ===== 标签文字 ===== -->
    <Style x:Key="Label_text" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#374151"/>
    </Style>

    <!-- ===== 次要说明文字 ===== -->
    <Style x:Key="DescText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#6B7280"/>
    </Style>

    <!-- ===== 状态指示点 ===== -->
    <Style x:Key="StatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Fill" Value="#22C55E"/>
    </Style>

    <!-- ===== 模型行容器 ===== -->
    <Style x:Key="ModelRow" TargetType="Border">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ===== 测试结果容器 ===== -->
    <Style x:Key="TestResultBox" TargetType="Border">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

</ResourceDictionary>
