<hc:Window x:Class="claude_model_setting.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:claude_model_setting.Views"
        xmlns:vm="clr-namespace:claude_model_setting.ViewModels"
        mc:Ignorable="d"
        Title="ModelLink" Height="760" Width="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <hc:Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <local:IndexToVisibilityConverter x:Key="IndexToVisibilityConverter" />
        </ResourceDictionary>
    </hc:Window.Resources>

    <DockPanel>
        <!-- 系统托盘图标 -->
        <hc:NotifyIcon Token="ModelLinkTray" Text="ModelLink - Claude Desktop 代理"
                       Icon="pack://application:,,,/Assets/tray_icon.ico">
            <hc:NotifyIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示窗口" Click="ShowWindow_Click"/>
                    <MenuItem Header="退出" Click="Exit_Click"/>
                </ContextMenu>
            </hc:NotifyIcon.ContextMenu>
            <hc:Interaction.Triggers>
                <hc:EventTrigger EventName="Click">
                    <hc:EventToCommand Command="{Binding ShowWindowCommand}"/>
                </hc:EventTrigger>
            </hc:Interaction.Triggers>
        </hc:NotifyIcon>

        <!-- Growl 消息通过代码调用 HandyControl.Controls.Growl 自动显示 -->

        <!-- 顶部标题栏 -->
        <Border DockPanel.Dock="Top" Padding="24,12" Margin="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ModelLink" FontSize="22" FontWeight="Bold" Foreground="#D97757"/>
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="16,0,6,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="运行中" FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="&#x2699;" FontSize="18" Opacity="0.5"
                        BorderThickness="0" Background="Transparent" Cursor="Hand"
                        Command="{Binding NavigateToSettingsCommand}" Width="36" Height="36"/>
            </DockPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid>
            <!-- ===== 主配置页 (index=0) ===== -->
            <hc:ScrollViewer VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding SelectedNavigationIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=0}">
                <StackPanel Margin="24" MaxWidth="800" HorizontalAlignment="Center">
                    <!-- Provider 卡片列表 -->
                    <ItemsControl ItemsSource="{Binding Providers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ProviderViewModel}">
                                <hc:Card MaxWidth="750" BorderThickness="0"
                                         Effect="{StaticResource EffectShadow2}"
                                         Margin="0,0,0,16" Padding="0">
                                    <StackPanel Margin="24">
                                        <!-- 卡片标题 + 删除 -->
                                        <DockPanel Margin="0,0,0,16">
                                            <TextBlock Text="{Binding DisplayTitle}"
                                                       Style="{StaticResource TextBlockLargeBold}"/>
                                            <Button DockPanel.Dock="Right" Content="删除服务商"
                                                    Foreground="{DynamicResource DangerBrush}"
                                                    BorderThickness="0" Background="Transparent" Cursor="Hand"
                                                    CommandParameter="{Binding}"
                                                    Click="DeleteProvider_Click"/>
                                        </DockPanel>

                                        <!-- API 地址 -->
                                        <hc:TextBox Text="{Binding TargetUrl, UpdateSourceTrigger=PropertyChanged}"
                                                    hc:InfoElement.Title="API 地址"
                                                    hc:InfoElement.TitleWidth="80"
                                                    hc:InfoElement.TitlePlacement="Left"
                                                    hc:InfoElement.Placeholder="https://api.deepseek.com/anthropic"
                                                    hc:InfoElement.ShowClearButton="True"
                                                    Margin="0,0,0,12"/>

                                        <!-- API 密钥 -->
                                        <hc:TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                    hc:InfoElement.Title="API 密钥"
                                                    hc:InfoElement.TitleWidth="80"
                                                    hc:InfoElement.TitlePlacement="Left"
                                                    hc:InfoElement.Placeholder="sk-xxx"
                                                    hc:InfoElement.ShowClearButton="True"
                                                    Margin="0,0,0,16"/>

                                        <!-- 模型列表标题 + 测试按钮 -->
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="模型列表" FontSize="12" Opacity="0.5"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <hc:LoadingCircle Width="16" Height="16"
                                                                  Visibility="{Binding IsTesting, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <Button Content="测试连接" Command="{Binding TestCommand}"
                                                        Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <!-- 测试结果 -->
                                        <Border CornerRadius="4" Padding="8,4" Margin="0,0,0,8"
                                                Background="{DynamicResource SuccessBrush}"
                                                Visibility="{Binding HasTestResult, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="{Binding TestResult}" FontSize="12" Foreground="White"/>
                                        </Border>

                                        <!-- 模型行列表 -->
                                        <ItemsControl ItemsSource="{Binding Models}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ModelEntryViewModel}">
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <hc:TextBox Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}"
                                                                    hc:InfoElement.Placeholder="如 deepseek-v4-pro"/>
                                                        <CheckBox Grid.Column="1" Content="1M"
                                                                  IsChecked="{Binding Is1mEnabled}"
                                                                  Margin="8,0" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="2" Content="x" Width="24" Height="24"
                                                                Opacity="0.3" BorderThickness="0" Background="Transparent"
                                                                CommandParameter="{Binding}"
                                                                Click="DeleteModel_Click"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 添加模型 -->
                                        <Button Content="+ 添加模型" Margin="0,8,0,0"
                                                Command="{Binding AddModelCommand}"
                                                HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </hc:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 添加服务商 -->
                    <Button Content="+ 添加服务商" Command="{Binding AddProviderCommand}"
                            Margin="0,0,0,24" HorizontalAlignment="Center"/>

                    <!-- 操作按钮 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="保存配置" Command="{Binding SaveConfigCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                Width="140" Height="36" Margin="0,0,12,0"/>
                        <Button Content="应用到 Claude Desktop" Command="{Binding ApplyToClaudeCommand}"
                                Style="{StaticResource ButtonSuccess}"
                                Width="200" Height="36"/>
                    </StackPanel>
                </StackPanel>
            </hc:ScrollViewer>

            <!-- ===== 设置页 (index=1) ===== -->
            <hc:ScrollViewer VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding SelectedNavigationIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=1}">
                <StackPanel Margin="24" MaxWidth="800" HorizontalAlignment="Center">
                    <!-- 返回按钮 -->
                    <Button Content="&#x2190; 返回" Command="{Binding NavigateToSettingsCommand}"
                            Margin="0,0,0,16" HorizontalAlignment="Left"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"/>

                    <!-- 自启动卡片 -->
                    <hc:Card BorderThickness="0" Effect="{StaticResource EffectShadow2}"
                             Margin="0,0,0,16" Padding="0">
                        <DockPanel Margin="24">
                            <TextBlock Text="开机自启动" Style="{StaticResource TextBlockLargeBold}"
                                       VerticalAlignment="Center"/>
                            <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding IsAutoStartEnabled}"/>
                        </DockPanel>
                    </hc:Card>

                    <!-- 请求日志卡片 -->
                    <hc:Card BorderThickness="0" Effect="{StaticResource EffectShadow2}"
                             Margin="0,0,0,16" Padding="0">
                        <StackPanel Margin="24">
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock Text="请求日志" Style="{StaticResource TextBlockLargeBold}"/>
                                <Button DockPanel.Dock="Right" Content="刷新"
                                        Command="{Binding RefreshLogsCommand}"/>
                            </DockPanel>
                            <ListView ItemsSource="{Binding Logs}" MaxHeight="300">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="时间" Width="80"
                                                        DisplayMemberBinding="{Binding Time}"/>
                                        <GridViewColumn Header="模型" Width="180"
                                                        DisplayMemberBinding="{Binding Model}"/>
                                        <GridViewColumn Header="状态" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Ellipse Width="6" Height="6" Margin="0,0,4,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                                            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding StatusText}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Opacity" Value="0.6"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                                            <Setter Property="Opacity" Value="1"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </hc:Card>

                    <!-- 作者信息 -->
                    <TextBlock Text="林子与咖啡 (免费软件，不可商业化)"
                               HorizontalAlignment="Center" Opacity="0.4" FontSize="11" Margin="0,8"/>
                </StackPanel>
            </hc:ScrollViewer>
        </Grid>
    </DockPanel>
</hc:Window>
